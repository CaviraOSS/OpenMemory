        "mammoth": "^1.11.0",
        "openai": "^4.73.0",
        "pdf-parse": "^2.4.5",
        "pg": "^8.16.3",
        "sqlite3": "^6.0.1",
        "turndown": "^7.2.2",
        "ws": "^8.18.3",
        "zod": "^3.25.76",
        "zod-to-json-schema": "^3.25.2"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.26",
        "@types/node": "^20.19.25",
        "@types/pg": "^8.15.6",
        "prettier": "^3.6.2",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
